---
/**
 * ApolloTracker.astro — Apollo.io website visitor tracking.
 *
 * Emits the Apollo script verbatim (as Apollo requires), placed just before
 * </head> via BaseHead. Only runs in production to avoid polluting Apollo
 * analytics with local / preview traffic.
 *
 * Must not use define:vars or any Astro script transformation — Apollo's
 * connection test checks for the exact script shape in the page source.
 */
const isProd = import.meta.env.PROD;
---
{isProd && (
  <script is:inline>
    function initApollo(){var n=Math.random().toString(36).substring(7),o=document.createElement("script");o.src="https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache="+n,o.async=!0,o.defer=!0,o.onload=function(){window.trackingFunctions.onLoad({appId:"69f949b454e7e60021818bee"})},document.head.appendChild(o)}initApollo();
  </script>
)}

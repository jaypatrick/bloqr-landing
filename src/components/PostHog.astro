---
/**
 * PostHog.astro — PostHog analytics integration.
 *
 * api_host points at the f.bloqr.dev subdomain reverse-proxy so analytics
 * calls are first-party and bypass ad blockers. The Cloudflare Worker routes
 * all f.bloqr.dev traffic to handlePostHogProxy (functions/posthog-proxy.ts).
 *
 * ui_host must point at the PostHog US instance so the toolbar, session-replay
 * links, and redirect flows resolve to the correct PostHog dashboard.
 *
 * Only active in production; no-ops locally so dev traffic never pollutes
 * the analytics dataset.
 */
const isProd = import.meta.env.PROD;
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
---

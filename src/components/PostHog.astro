---
/**
 * PostHog.astro — PostHog analytics integration.
 *
 * Split into two <script> tags to avoid Astro's compiler treating the `}`
 * characters inside the minified PostHog stub as template expression closures
 * when define:vars is present:
 *
 *   1. Plain is:inline — the static PostHog stub loader. No define:vars so
 *      Astro does not template-parse the minified content.
 *
 *   2. is:inline define:vars — posthog.init() with the runtime key injected,
 *      plus the astro:page-load listener for View Transitions pageview tracking.
 *
 * api_host points at the f.bloqr.dev subdomain reverse-proxy so analytics
 * calls are first-party and bypass ad blockers.
 *
 * ui_host is intentionally omitted — toolbar auth flows route through api_host
 * (f.bloqr.dev → Worker proxy → us.i.posthog.com). Setting ui_host breaks
 * the toolbar auth handshake when using a dedicated subdomain proxy.
 *
 * capture_pageview: false — astro:page-load fires $pageview manually on every
 * navigation (initial load + all ClientRouter soft navs). Without this,
 * only the first hard load would be tracked.
 *
 * Server-side tracking (posthog-node):
 *   - src/lib/posthog-server.ts   — singleton (flushAt:1, flushInterval:0)
 *   - functions/waitlist.ts       — waitlist_signup_server capture
 *   Requires: wrangler secret put POSTHOG_PROJECT_TOKEN
 *
 * Only active in production to keep dev traffic out of the analytics dataset.
 */
const isProd = import.meta.env.PROD;
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
---
{isProd && posthogKey && (
  <>
    {/* Script 1: static PostHog stub — no define:vars to avoid template parsing of minified content */}
    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}var m=e;for(void 0!==a?m=e[a]=[]:a="posthog",m.people=m.people||[],m.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},m.people.toString=function(){return m.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(m,o[n]);var y=t.createElement("script");y.type="text/javascript",y.crossOrigin="anonymous",y.async=!0,y.src=s.api_host.replace(".i.posthog.com","-assets.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(y,r)}(window,window.posthog||[])}(document,window.posthog||[]);
    </script>

    {/* Script 2: init with runtime key + astro:page-load pageview listener */}
    <script is:inline define:vars={{ posthogKey }}>
      posthog.init(posthogKey, {
        api_host:         'https://f.bloqr.dev',
        defaults:         '2026-01-30',
        capture_pageview: false,
      });

      // Capture $pageview on every Astro ClientRouter (View Transitions) navigation.
      // astro:page-load fires on initial hard load AND every soft navigation,
      // making it the single source of truth for all pageview tracking.
      document.addEventListener('astro:page-load', function () {
        if (window.posthog) {
          window.posthog.capture('$pageview');
        }
      });
    </script>
  </>
)}

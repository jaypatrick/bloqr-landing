---
/**
 * BaseHead.astro — shared <head> block for all pages.
 *
 * Renders charset, viewport, title, description, Open Graph, Twitter/X card,
 * canonical link, RSS link, favicon, PWA manifest, theme-color, font preloads
 * (via Astro 6 Fonts API), OG image preload, ClientRouter (View Transitions),
 * Plausible analytics, PostHog analytics, Cloudflare Web Analytics,
 * and Apollo.io website tracker.
 */
import { ClientRouter } from 'astro:transitions'; // Astro 6 replacement for ViewTransitions
import Font from 'astro/components/Font.astro';
import { SITE_URL } from '../config';
import Analytics from './Analytics.astro';
import ApolloTracker from './ApolloTracker.astro';
import CloudflareAnalytics from './CloudflareAnalytics.astro';
import PostHog from './PostHog.astro';

interface Props {
  title: string;
  description: string;
  /** Absolute URL for the canonical link. Defaults to current page URL. */
  canonicalURL?: URL | string;
  /** Absolute URL for OG/Twitter image. Defaults to ${SITE_URL}/og-image.png. */
  ogImage?: string;
  /** Width of the OG image in pixels. Defaults to 1200. */
  ogImageWidth?: number;
  /** Height of the OG image in pixels. Defaults to 630. */
  ogImageHeight?: number;
  /** OG type. Defaults to 'website'. */
  ogType?: string;
  /** Author name for <meta name="author">. Defaults to 'Jayson Knight'. */
  author?: string;
  /** When true, adds <meta name="robots" content="noindex, nofollow">. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalURL = Astro.url,
  ogImage = `${SITE_URL}/og-image.png`,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogType = 'website',
  author = 'Jayson Knight',
  noindex = false,
} = Astro.props;

const canonical = canonicalURL.toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="color-scheme" content="dark light" />

<!-- Open Graph -->
<meta property="og:site_name"    content="Bloqr" />
<meta property="og:title"        content={title} />
<meta property="og:description"  content={description} />
<meta property="og:url"          content={canonical} />
<meta property="og:image"        content={ogImage} />
<meta property="og:image:width"  content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:alt"    content={title} />
<meta property="og:type"         content={ogType} />
<meta property="og:locale"       content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImage} />
<meta name="twitter:image:alt"   content={title} />
<meta name="twitter:site"        content="@bloqr_ai" />
<meta name="twitter:creator"     content="@jaysonknight" />

<!-- Canonical -->
<link rel="canonical" href={canonical} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Bloqr Blog" href="/rss.xml" />

<!-- Favicon -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192" />
<link rel="apple-touch-icon" href="/icon-192.png" />

<!-- PWA / Theme -->
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#FF5500" />

<!-- Preconnect to third-party analytics origins to reduce connection latency -->
<!-- Note: PostHog is proxied through /ingest on this origin — no external preconnect needed -->
<link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />
<link rel="dns-prefetch" href="//static.cloudflareinsights.com" />
<link rel="dns-prefetch" href="//assets.apollo.io" />

<!-- Astro 6 Fonts API — self-hosted via fontsource, with preload links -->
<Font cssVariable="--font-display" preload />
<Font cssVariable="--font-mono" preload />

{noindex && <meta name="robots" content="noindex, nofollow" />}

<ClientRouter />
<Analytics />
<PostHog />
<CloudflareAnalytics />
<ApolloTracker />

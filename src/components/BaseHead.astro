---
/**
 * BaseHead.astro — shared <head> block for all pages.
 *
 * Renders charset, viewport, title, description, Open Graph, Twitter/X card,
 * canonical link, RSS link, favicon, PWA manifest, theme-color, font preconnects,
 * OG image preload, ViewTransitions, Plausible analytics, and PostHog analytics.
 */
import { ViewTransitions } from 'astro:transitions';
import { SITE_URL } from '../config';
import Analytics from './Analytics.astro';
import PostHog from './PostHog.astro';

interface Props {
  title: string;
  description: string;
  /** Absolute URL for the canonical link. Defaults to current page URL. */
  canonicalURL?: URL | string;
  /** Absolute URL for OG/Twitter image. Defaults to ${SITE_URL}/og-image.png. */
  ogImage?: string;
  /** OG type. Defaults to 'website'. */
  ogType?: string;
  /** When true, adds <meta name="robots" content="noindex, nofollow">. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalURL = Astro.url,
  ogImage = `${SITE_URL}/og-image.png`,
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonical = canonicalURL.toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Jayson Knight" />
<meta name="color-scheme" content="dark" />

<!-- Open Graph -->
<meta property="og:site_name"    content="Bloqr" />
<meta property="og:title"        content={title} />
<meta property="og:description"  content={description} />
<meta property="og:url"          content={canonical} />
<meta property="og:image"        content={ogImage} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"    content={title} />
<meta property="og:type"         content={ogType} />
<meta property="og:locale"       content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImage} />
<meta name="twitter:image:alt"   content={title} />
<meta name="twitter:site"        content="@bloqr_ai" />
<meta name="twitter:creator"     content="@jaysonknight" />

<!-- Canonical -->
<link rel="canonical" href={canonical} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Bloqr Blog" href="/rss.xml" />

<!-- Favicon (inline SVG data URI) -->
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%23070B14'/><rect x='6' y='6' width='20' height='3' rx='1.5' fill='%23F1F5F9'/><rect x='6' y='13' width='15' height='3' rx='1.5' fill='%23F1F5F9' opacity='.65'/><rect x='6' y='20' width='8' height='3' rx='1.5' fill='%23FF5500'/></svg>" />

<!-- PWA / Theme -->
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#FF5500" />

<!-- Preconnect for Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
<link rel="dns-prefetch" href="https://fonts.gstatic.com" />

<!-- TODO: Extract Space Grotesk to public/fonts/ for preloading;
     currently loaded via CSS @import from node_modules — not preloadable this way. -->

{noindex && <meta name="robots" content="noindex, nofollow" />}

<ViewTransitions />
<Analytics />
<PostHog />

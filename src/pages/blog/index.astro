---
import '../../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Nav from '../../components/Nav.svelte';
import Footer from '../../components/Footer.svelte';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { getCollection } from 'astro:content';
import { SITE_URL, META } from '../../config';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const meta = {
  title:       'Bloqr Blog — Education, Industry News & Releases',
  description: 'DNS blocking explainers for everyday users, VPN incident coverage, and feature release notes from the Bloqr team.',
  url:         `${SITE_URL}/blog`,
  image:       `${SITE_URL}${META.ogImage}`,
};

const blogIndexSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Bloqr Blog",
  "url": `${SITE_URL}/blog`,
  "description": meta.description,
  "blogPost": allPosts.map((post) => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "url": `${SITE_URL}/blog/${post.slug}`,
    "datePublished": post.data.pubDate.toISOString(),
    "description": post.data.description
  }))
};

const categoryLabel: Record<string, string> = {
  education: 'Education',
  industry:  'Industry News',
  release:   'Release',
};

const categoryClass: Record<string, string> = {
  education: 'badge-cyan',
  industry:  'badge-orange',
  release:   'badge-green',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{meta.title}</title>
  <meta name="description" content={meta.description} />
  <!-- Open Graph -->
  <meta property="og:site_name"    content="Bloqr" />
  <meta property="og:title"        content={meta.title} />
  <meta property="og:description"  content={meta.description} />
  <meta property="og:url"          content={meta.url} />
  <meta property="og:image"        content={meta.image} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"    content="Bloqr Blog — Education, Industry News & Releases" />
  <meta property="og:type"         content="website" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={meta.title} />
  <meta name="twitter:description" content={meta.description} />
  <meta name="twitter:image"       content={meta.image} />
  <meta name="twitter:image:alt"   content="Bloqr Blog — Education, Industry News & Releases" />
  <meta name="twitter:site"        content="@bloqr_ai" />
  <meta name="twitter:creator"     content="@jaysonknight" />

  <!-- Author -->
  <meta name="author" content="Jayson Knight" />

  <!-- Color scheme -->
  <meta name="color-scheme" content="dark" />

  <!-- OG locale -->
  <meta property="og:locale" content="en_US" />

  <link rel="canonical" href={meta.url} />
  <link rel="alternate"   type="application/rss+xml" title="Bloqr Blog" href="/rss.xml" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%23070B14'/><rect x='6' y='6' width='20' height='3' rx='1.5' fill='%23F1F5F9'/><rect x='6' y='13' width='15' height='3' rx='1.5' fill='%23F1F5F9' opacity='.65'/><rect x='6' y='20' width='8' height='3' rx='1.5' fill='%23FF5500'/></svg>" />

  <!-- PWA / Theme -->
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#FF5500" />

  <ViewTransitions />
  <SchemaOrg schema={blogIndexSchema} />
</head>
<body>
  <Nav client:idle />

  <main id="main-content" class="blog-index">

    <header class="page-header">
      <div class="container">
        <div class="header-label">From the team</div>
        <div class="header-title-row">
          <h1>What's going on<br /><em>at Bloqr.</em></h1>
          <a href="/rss.xml" class="rss-icon-link" aria-label="Subscribe via RSS feed">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="var(--orange)" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20 4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          </a>
        </div>
        <p class="header-sub">
          User education. Industry watchdogging. The occasional deep-dive for people who like to
          understand what their software is actually doing. Subscribe via
          <a href="/rss.xml" class="rss-link">RSS</a> if you're that kind of person.
        </p>
      </div>
    </header>

    <section class="posts-section">
      <div class="container">

        {allPosts.length === 0 && (
          <p class="empty">Nothing here yet. Check back soon.</p>
        )}

        <div class="posts-grid">
          {allPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-meta">
                <span class={`badge ${categoryClass[post.data.category]}`}>
                  {categoryLabel[post.data.category]}
                </span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="read-more">Read more →</span>
            </a>
          ))}
        </div>

      </div>
    </section>

  </main>

  <Footer />
</body>
</html>

<style>
  /* ── Page header ── */
  .page-header {
    padding: 96px 0 56px;
    border-bottom: 1px solid var(--border);
  }

  .header-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .header-title-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }

  .header-title-row h1 { margin-bottom: 0; }

  .rss-icon-link {
    display: inline-flex;
    align-items: center;
    padding-top: 8px;
    opacity: 0.85;
    transition: opacity 150ms;
    flex-shrink: 0;
  }

  .rss-icon-link:hover { opacity: 1; }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-1);
    margin-bottom: 20px;
  }

  .page-header h1 em {
    font-style: normal;
    color: var(--cyan);
  }

  .header-sub {
    max-width: 560px;
    color: var(--text-2);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .rss-link {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid var(--orange-dim);
    transition: border-color 150ms;
  }
  .rss-link:hover { border-bottom-color: var(--orange); }

  /* ── Posts ── */
  .posts-section { padding: 64px 0 96px; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    transition: border-color 150ms, transform 150ms;
  }

  .post-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .badge-cyan   { background: var(--cyan-dim);   color: var(--cyan);   }
  .badge-orange { background: var(--orange-dim); color: var(--orange); }
  .badge-green  {
    background: rgba(52, 211, 153, 0.12);
    color: #34d399;
  }

  .post-meta time {
    font-size: 13px;
    color: var(--text-3);
  }

  .post-title {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--text-1);
    line-height: 1.4;
    margin-bottom: 12px;
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }

  .read-more {
    font-size: 13px;
    font-weight: 600;
    color: var(--orange);
    transition: color 150ms;
  }

  .post-card:hover .read-more { color: var(--orange-hover); }

  .empty { color: var(--text-3); font-size: 1rem; }

  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
    .page-header { padding: 64px 0 40px; }
  }
</style>

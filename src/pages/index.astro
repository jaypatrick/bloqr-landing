---
export const prerender = true;
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import Hero from '../components/Hero.svelte';
import SocialProof from '../components/SocialProof.svelte';
import ComingSoon from '../components/ComingSoon.svelte';
import Problem from '../components/Problem.svelte';
import BeforeAfter from '../components/BeforeAfter.svelte';
import HowItWorks from '../components/HowItWorks.svelte';
import Audiences from '../components/Audiences.svelte';
import Features from '../components/Features.svelte';
import WaitlistSignup from '../components/WaitlistSignup.svelte';
import CodeDemo from '../components/CodeDemo.svelte';
import DynamicWorkers from '../components/DynamicWorkers.svelte';
import WhyCloudflare from '../components/WhyCloudflare.svelte';
import PrivacyCommitments from '../components/PrivacyCommitments.svelte';
import Pricing from '../components/Pricing.svelte';
import FounderNote from '../components/FounderNote.svelte';
import FAQ from '../components/FAQ.svelte';
import CtaBanner from '../components/CtaBanner.svelte';
import Footer from '../components/Footer.svelte';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_URL, META } from '../config';

const meta = {
  title:       META.title,
  description: META.description,
  url:         SITE_URL,
  image:       `${SITE_URL}/og/home.png`,  // dynamically generated at build time
};

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Bloqr",
      "description": META.description,
      "url": SITE_URL,
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Web, iOS, Android, macOS, Windows",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free tier available on waitlist"
      },
      "featureList": "DNS-level ad blocking, AI-powered filter lists, Encrypted DNS (DoH/DoT), Network-wide protection, Real-time threat intelligence, Bring-your-own DNS provider support"
    },
    {
      "@type": "Organization",
      "name": "Bloqr",
      "url": SITE_URL,
      "logo": `${SITE_URL}/og-image.png`,
      "sameAs": ["https://twitter.com/bloqr_ai", "https://github.com/jaypatrick/adblock-compiler"],
      "foundingDate": "2026",
      "description": "Making internet hygiene that protects experts automatically work for everyone."
    },
    {
      "@type": "WebSite",
      "name": "Bloqr",
      "url": SITE_URL,
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${SITE_URL}/blog?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does Bloqr see my internet traffic?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Bloqr never proxies your connection, routes your traffic, or sits in the path between you and the internet. It compiles filter lists and pushes them to your DNS filtering service. What gets blocked is decided at the DNS level by your chosen vendor — not by Bloqr."
          }
        },
        {
          "@type": "Question",
          "name": "What's the difference between Bloqr and a VPN?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A VPN reroutes all your traffic through someone else's server — you're trusting them instead of your ISP. Bloqr doesn't touch your traffic at all. It builds and maintains the blocklists your DNS filtering service uses to stop ads and trackers before they even load. No tunnel. No rerouting. No new party to trust."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use my existing Pi-hole / AdGuard / NextDNS setup?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Bloqr is vendor-agnostic by design. Connect your existing setup and Bloqr manages the list updates, transformations, and deployments. Your filtering engine stays exactly where it is — Bloqr just makes it smarter. If you don't have one yet, we'll help you pick and set one up."
          }
        },
        {
          "@type": "Question",
          "name": "What happens to my data if I cancel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can export your full configuration (lists, rules, settings) as JSON at any time. If you cancel, your data is deleted within 30 days. No hostage data. The GPL-3.0 open-source version means you can always self-host and never be locked out."
          }
        },
        {
          "@type": "Question",
          "name": "Is the compiler itself open source?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The adblock filter list compiler at the core of Bloqr is GPL-3.0 licensed and available on GitHub. The managed platform (AI features, vendor integrations, dashboard) is a paid product, but the engine is yours to run, fork, and audit."
          }
        },
        {
          "@type": "Question",
          "name": "What does \"AI-powered\" actually mean here?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Two things: (1) natural language rule building — tell Bloqr what you want to block in plain English and it translates that into proper filter rules; (2) real-time threat intelligence — AI continuously monitors emerging malware domains and phishing campaigns and surfaces them as filter list updates. No magic. No vague claims."
          }
        }
      ]
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={meta.title}
    description={meta.description}
    canonicalURL={meta.url}
    ogImage={meta.image}
  />
  <SchemaOrg schema={homeSchema} />
  <meta name="keywords" content="adblock, DNS filtering, ad blocking, tracker blocking, Pi-hole, AdGuard, NextDNS, DoH, DNS over HTTPS, internet privacy, network security" />
</head>
<body>
  <Nav client:idle transition:persist="nav" />
  <main id="main-content">
    <Hero client:idle />
    <ComingSoon client:visible />
    <div class="divider-glow"></div>
    <Problem />
    <BeforeAfter client:visible />
    <HowItWorks client:visible />
    <Audiences client:visible />
    <div class="animate-on-scroll"><Features /></div>
    <DynamicWorkers />
    <WhyCloudflare />
    <div class="animate-on-scroll"><PrivacyCommitments /></div>
    <div class="animate-on-scroll"><Pricing /></div>
    <div class="animate-on-scroll"><FounderNote /></div>
    <FAQ client:visible />
    <WaitlistSignup client:visible />
    <CodeDemo client:visible />
    <div class="animate-on-scroll"><CtaBanner /></div>
  </main>
  <Footer />
</body>
</html>

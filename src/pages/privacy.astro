---
export const prerender = true;
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_URL, META } from '../config';

const meta = {
  title:       'Privacy Policy — Bloqr AI',
  description: 'Plain-English privacy policy for Bloqr AI. What we collect, what we never collect, and your rights.',
  url:         `${SITE_URL}/privacy`,
  image:       `${SITE_URL}${META.ogImage}`,
};

const privacySchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": meta.url,
      "name": meta.title,
      "url": meta.url,
      "description": meta.description,
      "additionalType": "https://schema.org/PrivacyPolicy"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": `${SITE_URL}/privacy` }
      ]
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={meta.title}
    description={meta.description}
    canonicalURL={meta.url}
    ogImage={meta.image}
  />
  <SchemaOrg schema={privacySchema} />
</head>
<body>
  <Nav client:load transition:persist="nav" />

  <main id="main-content" class="legal-page">

    <header class="page-header">
      <div class="container">
        <div class="header-label">Legal</div>
        <h1>Bloqr Privacy Policy</h1>
        <p class="effective-date">Effective date: April 2026 (pre-launch)</p>
      </div>
    </header>

    <div class="container prose-wrap">

      <section class="prose-section" aria-labelledby="collect-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">What we collect</span>
          </div>
          <div class="prose-body">
            <h2 id="collect-heading">What we collect</h2>
            <ul>
              <li><strong>Email address</strong> — if you join the waitlist. Used only to notify you when access is ready.</li>
              <li><strong>Segment choice</strong> — optional. Which audience type best describes you (List Maker, Privacy Vendor, or Individual). Helps us prioritise who gets early access first.</li>
              <li><strong>IP address and HTTP referrer</strong> — logged at the time of waitlist signup, for aggregate analytics only. Not sold, not profiled, not linked to any third-party ad system.</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="never-collect-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">What we never collect</span>
          </div>
          <div class="prose-body">
            <h2 id="never-collect-heading">What we never collect</h2>
            <ul>
              <li>DNS queries or browsing history — not logged, not stored, not analysed.</li>
              <li>Device fingerprints.</li>
              <li>Behavioral data or usage patterns from your network.</li>
              <li>Any data from your connected DNS filtering service (Pi-hole, AdGuard, NextDNS, etc.).</li>
            </ul>
            <p>This is a technical architecture decision, not marketing language. The data that doesn't exist can't be produced in response to a subpoena, sold in a bankruptcy, or leaked in a breach.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="use-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">How we use it</span>
          </div>
          <div class="prose-body">
            <h2 id="use-heading">How we use it</h2>
            <ul>
              <li>Your email is used for one purpose: to contact you when your early access is ready.</li>
              <li>IP address and referrer are used only for aggregate analytics (e.g., "how many signups came from organic search vs. a specific link"). They are not used for individual profiling.</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="third-parties-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Third parties</span>
          </div>
          <div class="prose-body">
            <h2 id="third-parties-heading">Third parties</h2>
            <ul>
              <li><strong>Neon</strong> — our database provider. Waitlist data is stored in Neon's infrastructure across EU/US data centers. <a href="https://neon.tech/privacy-policy" rel="noopener noreferrer" target="_blank">Neon privacy policy →</a></li>
              <li><strong>Apollo.io</strong> — CRM platform. Waitlist email and segment are synced to Apollo for the sole purpose of managing early access outreach. Apollo does not receive IP addresses, referrers, or any browsing data.</li>
              <li><strong>Cloudflare</strong> — all web traffic passes through Cloudflare's network as our infrastructure provider. <a href="https://www.cloudflare.com/privacypolicy/" rel="noopener noreferrer" target="_blank">Cloudflare privacy policy →</a></li>
            </ul>
            <p>We do not sell or license your data to any other third party under any circumstances.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="rights-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Your rights</span>
          </div>
          <div class="prose-body">
            <h2 id="rights-heading">Your rights</h2>
            <p>You can request deletion of your data at any time by emailing <a href="mailto:privacy@bloqr.ai">privacy@bloqr.ai</a>. We'll respond within 30 days and confirm once deletion is complete.</p>
            <p>If you're in the EU, you also have the right to access, rectify, and port your data under GDPR. Same email address.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="cookies-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">No cookies</span>
          </div>
          <div class="prose-body">
            <h2 id="cookies-heading">No cookies</h2>
            <p>The Bloqr landing page uses no tracking cookies, no analytics scripts, and no third-party pixels. We don't set any cookies at all on this page. There's nothing to accept or decline.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="contact-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Contact</span>
          </div>
          <div class="prose-body">
            <h2 id="contact-heading">Contact</h2>
            <p>Privacy questions: <a href="mailto:privacy@bloqr.ai">privacy@bloqr.ai</a></p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  .legal-page { color: var(--text-1); }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .page-header {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--border);
  }

  .header-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .effective-date {
    font-size: 0.85rem;
    color: var(--text-3);
  }

  .prose-wrap {
    padding-top: 0;
    padding-bottom: 80px;
  }

  .prose-section {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }

  .prose-grid {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 700px) {
    .prose-grid { grid-template-columns: 1fr; gap: 12px; }
    .prose-sidebar { display: none; }
  }

  .prose-sidebar { padding-top: 6px; }

  .sidebar-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .prose-body h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-1);
  }

  .prose-body p {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .prose-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .prose-body li {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.65;
    padding-left: 18px;
    position: relative;
  }

  .prose-body li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--text-3);
    font-size: 0.8rem;
  }

  .prose-body strong { color: var(--text-1); }

  .prose-body a {
    color: var(--orange);
    text-decoration: none;
    transition: color 150ms;
  }

  .prose-body a:hover { color: var(--orange-hover); }
</style>

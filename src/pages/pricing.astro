---
export const prerender = true;
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Pricing from '../components/Pricing.svelte';
import PricingTable from '../components/PricingTable.svelte';
import ConversionCalculator from '../components/ConversionCalculator.svelte';
import { SITE_URL, LINKS, PAGE_META } from '../config';

const meta = {
  title:       PAGE_META.pricing.title,
  description: PAGE_META.pricing.description,
  url:         `${SITE_URL}/pricing`,
  image:       `${SITE_URL}/og/pricing.png`,
};

const pricingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": meta.title,
      "description": meta.description,
      "url": meta.url,
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",    "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Pricing", "item": meta.url },
      ]
    },
    {
      "@type": "Offer",
      "name": "Personal",
      "description": "AI-curated filter list for households who just want it handled.",
      "price": "5.00",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "5.00",
        "priceCurrency": "USD",
        "unitText": "MONTH"
      },
      "url": meta.url
    },
    {
      "@type": "Offer",
      "name": "Pay As You Go",
      "description": "Try the full Bloqr compilation pipeline. Pay per compile via Stripe.",
      "price": "0.01",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "0.01",
        "priceCurrency": "USD",
        "unitText": "compile"
      },
      "url": `${meta.url}#payg`
    },
    {
      "@type": "Offer",
      "name": "Pro (Power User)",
      "description": "Custom transformation pipelines, natural language rule builder, API access, and more.",
      "price": "9.00",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "9.00",
        "priceCurrency": "USD",
        "unitText": "MONTH"
      },
      "url": meta.url
    },
    {
      "@type": "Offer",
      "name": "Developer / Self-Hosted",
      "description": "GPL-3.0 open-source compiler — run it yourself, forever free.",
      "price": "0",
      "priceCurrency": "USD",
      "url": LINKS.github
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={meta.title}
    description={meta.description}
    canonicalURL={meta.url}
    ogImage={meta.image}
  />
  <SchemaOrg schema={pricingSchema} />
</head>
<body>
  <Nav client:idle transition:persist="nav" />

  <main id="main-content">

    <!-- ── Page header ── -->
    <header class="page-header">
      <div class="container">
        <div class="header-label">Pricing</div>
        <h1>Simple pricing.<br /><em>No surprises.</em></h1>
        <p class="header-sub">
          Start for free, pay per compile, or subscribe. Early access locks in your rate
          for the life of the account. No crypto. No wallet. Just a card.
        </p>
        <div class="header-cta">
          <a href="/#waitlist" class="btn btn-primary">Join Early Access →</a>
          <a href="#compare"   class="btn btn-outline">Compare all plans</a>
        </div>
      </div>
    </header>

    <!-- ── Pricing tiers (reused component) ── -->
    <Pricing />

    <!-- ── PAYG detail section ── -->
    <section class="payg-section" id="payg" aria-labelledby="payg-heading">
      <div class="container">
        <div class="payg-grid">
          <div class="payg-content">
            <p class="section-label">Pay As You Go</p>
            <h2 id="payg-heading">Try before you subscribe.<br />Pay per compile.</h2>
            <p>
              Pay As You Go lets you use the full Bloqr compilation pipeline without signing
              up for a subscription. Add a card via Stripe, get charged $0.01 per compile call.
              When your monthly usage crosses the cost of a Pro subscription, we'll show you
              exactly how much you'd save — one click to switch.
            </p>
            <p>
              Your session token covers multiple API calls, so you're not re-entering payment
              details every time. The mechanism is automatic and invisible — you just call the API.
            </p>
            <a href="/#waitlist" class="btn btn-outline">Get early access</a>
          </div>

          <!-- CSS-only flow diagram -->
          <div class="payg-flow" aria-label="Pay As You Go flow: Add card, API call, Session issued, N calls covered, Auto-upsell at threshold">
            <div class="flow-step">
              <div class="flow-icon">💳</div>
              <div class="flow-label">Add card</div>
            </div>
            <div class="flow-arrow" aria-hidden="true">→</div>
            <div class="flow-step">
              <div class="flow-icon">⚡</div>
              <div class="flow-label">API call</div>
            </div>
            <div class="flow-arrow" aria-hidden="true">→</div>
            <div class="flow-step">
              <div class="flow-icon">🔑</div>
              <div class="flow-label">Session issued</div>
            </div>
            <div class="flow-arrow" aria-hidden="true">→</div>
            <div class="flow-step">
              <div class="flow-icon">🔁</div>
              <div class="flow-label">N calls covered</div>
            </div>
            <div class="flow-arrow" aria-hidden="true">→</div>
            <div class="flow-step flow-step--highlight">
              <div class="flow-icon">📈</div>
              <div class="flow-label">Auto-upsell at threshold</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Comparison table ── -->
    <div id="compare">
      <PricingTable />
    </div>

    <!-- ── Conversion calculator ── -->
    <ConversionCalculator client:visible />

    <!-- ── API Marketplace section ── -->
    <section class="marketplace-section" aria-labelledby="marketplace-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label">API Networks</p>
          <h2 id="marketplace-heading" class="section-title">
            Find Bloqr on the API networks you already use.
          </h2>
          <p class="section-sub">
            On marketplace platforms that handle billing, your existing account covers
            everything. On discovery platforms, Pay As You Go lets you start without a
            separate signup.
          </p>
        </div>

        <div class="marketplace-grid">
          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">RapidAPI</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Subscribe via RapidAPI. Their platform handles billing — your existing RapidAPI
              account covers Bloqr usage alongside any other APIs you use.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">Postman API Network</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Discover and test Bloqr's API directly in Postman. Start with Pay As You Go —
              no separate account needed.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Billing FAQ ── -->
    <section class="faq-section" aria-labelledby="faq-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label">Billing FAQ</p>
          <h2 id="faq-heading" class="section-title">Questions about billing.</h2>
        </div>

        <div class="faq-list">
          <details class="faq-item">
            <summary>Do I need a credit card to try Bloqr?</summary>
            <div class="faq-answer">
              No. The free tier requires no payment information. Create an account and start
              compiling immediately — no card, no commitment.
            </div>
          </details>

          <details class="faq-item">
            <summary>How does Pay As You Go billing work?</summary>
            <div class="faq-answer">
              Add a card via Stripe once. Each compile call costs $0.01 and is charged
              automatically. You receive an itemised receipt after each session. There's no
              minimum spend and no monthly fee — you only pay for what you use.
            </div>
          </details>

          <details class="faq-item">
            <summary>Can I switch from Pay As You Go to a subscription?</summary>
            <div class="faq-answer">
              Yes — one click. When your usage approaches the cost of a Pro subscription,
              Bloqr shows you the exact savings. Switch at any time from your account dashboard.
              Your existing usage in the current period is credited.
            </div>
          </details>

          <details class="faq-item">
            <summary>What happens if I hit the daily Pay As You Go limit?</summary>
            <div class="faq-answer">
              Requests are queued until the next calendar day (UTC). No surprise charges —
              the cap is absolute. If you regularly hit the 500/day limit, upgrading to Pro
              removes it entirely.
            </div>
          </details>

          <details class="faq-item">
            <summary>Is there a free trial for Pro?</summary>
            <div class="faq-answer">
              All paid tiers include a 30-day money-back guarantee, no questions asked.
              Cancel within 30 days and you'll receive a full refund.
            </div>
          </details>

          <details class="faq-item">
            <summary>Can my company pay by invoice?</summary>
            <div class="faq-answer">
              Vendor and Enterprise plans support invoice billing and purchase order workflows.
              <a href="/#waitlist">Contact us</a> to discuss your requirements.
            </div>
          </details>

          <details class="faq-item">
            <summary>Is Bloqr available on RapidAPI?</summary>
            <div class="faq-answer">
              A RapidAPI listing is coming soon. When live, your existing RapidAPI account
              will cover Bloqr usage — no separate Bloqr account or payment method required.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- ── Final CTA ── -->
    <section class="pricing-cta" aria-label="Get started with Bloqr">
      <div class="container">
        <h2>Internet Hygiene. Automated.</h2>
        <p>Set it. Bloqr it. Forget it.</p>
        <div class="cta-actions">
          <a href="/#waitlist" class="btn btn-primary">Join Early Access →</a>
          <a href={LINKS.docs} class="btn btn-outline" rel="noopener noreferrer" target="_blank">
            Read the docs
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</body>
</html>

<style>
  /* ── Page header ── */
  .page-header {
    padding: 96px 0 72px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse at center, rgba(255,85,0,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .header-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 20px;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-header h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--orange) 0%, #FF8833 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-sub {
    font-size: 1.05rem;
    color: var(--text-2);
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .header-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 150ms;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--orange);
    color: #fff;
    box-shadow: 0 0 20px rgba(255, 85, 0, 0.3);
  }
  .btn-primary:hover {
    background: var(--orange-hover);
    box-shadow: 0 0 32px rgba(255, 85, 0, 0.45);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-1);
    border: 1px solid var(--border-2);
  }
  .btn-outline:hover {
    border-color: var(--text-3);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Section labels (reusable within page) ── */
  .section-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--text-1);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 0.97rem;
    color: var(--text-2);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  /* ── PAYG detail section ── */
  .payg-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
    background: rgba(0, 212, 255, 0.02);
  }

  .payg-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 800px) {
    .payg-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .payg-content h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .payg-content p {
    font-size: 0.97rem;
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  /* ── CSS-only flow diagram ── */
  .payg-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    min-width: 90px;
    text-align: center;
  }

  .flow-step--highlight {
    border-color: var(--orange);
    background: rgba(255, 85, 0, 0.06);
  }

  .flow-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .flow-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-2);
    text-align: center;
    white-space: nowrap;
  }

  .flow-arrow {
    color: var(--text-3);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* ── API Marketplace section ── */
  .marketplace-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .marketplace-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 640px) {
    .marketplace-grid { grid-template-columns: 1fr; }
  }

  .marketplace-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
  }

  .marketplace-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .marketplace-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-1);
  }

  .coming-soon-badge {
    background: var(--bg-elevated);
    border: 1px solid var(--border-2);
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
    white-space: nowrap;
  }

  .marketplace-card p {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Billing FAQ section ── */
  .faq-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-item {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 150ms;
  }

  .faq-item[open] {
    border-color: var(--border-2);
  }

  .faq-item summary {
    padding: 18px 22px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    color: var(--text-3);
    font-size: 1.1rem;
    font-weight: 400;
    flex-shrink: 0;
    transition: transform 200ms;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 22px 18px;
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  .faq-answer a {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Final CTA ── */
  .pricing-cta {
    padding: 96px 0;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .pricing-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .pricing-cta p {
    font-size: 1.1rem;
    color: var(--text-3);
    margin-bottom: 36px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

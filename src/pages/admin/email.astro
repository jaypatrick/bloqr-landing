---
export const prerender = true;
/**
 * src/pages/admin/email.astro — /admin/email
 *
 * Admin UI for the email service:
 *   - Configuration status: shows which env vars are present and which send
 *     strategy will be used (service binding vs MailChannels direct).
 *   - Template preview: renders any registered template to HTML and plain-text.
 *   - Test send: delivers a rendered template to a real email address.
 *
 * Auth: same dual-gate pattern as admin/config.astro.
 * Security enforced server-side by the /admin/email/* edge functions.
 */
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Email Admin — Bloqr</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    :root {
      --bg-base:     #070B14;
      --bg-surface:  #0E1829;
      --bg-elevated: #162035;
      --orange:      #FF5500;
      --cyan:        #00D4FF;
      --green:       #22c55e;
      --red:         #ef4444;
      --text-1:      #F1F5F9;
      --text-2:      #94A3B8;
      --text-3:      #475569;
      --border:      #1E2D40;
      --border-2:    #2A3F5A;
      --font-display: system-ui, sans-serif;
      --font-mono:    monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-base);
      color: var(--text-1);
      font-family: var(--font-display);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      padding: 32px 24px;
    }

    .container { max-width: 960px; margin: 0 auto; }

    h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
    h2 { font-size: 1.05rem; font-weight: 600; margin-bottom: 16px; color: var(--text-2); }

    .breadcrumb {
      font-size: 0.8rem;
      color: var(--text-3);
      margin-bottom: 24px;
    }
    .breadcrumb a { color: var(--cyan); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    .section {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 20px;
    }

    /* ── Status dots ── */
    .status-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
      margin-bottom: 16px;
    }
    .status-item {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.8rem;
    }
    .status-item .key { font-family: var(--font-mono); color: var(--cyan); font-size: 0.75rem; }
    .status-item .val { margin-top: 4px; font-weight: 600; }
    .val.yes { color: var(--green); }
    .val.no  { color: var(--red); }

    .strategy-badge {
      display: inline-block;
      background: rgba(0, 212, 255, 0.1);
      border: 1px solid rgba(0, 212, 255, 0.3);
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 0.78rem;
      font-family: var(--font-mono);
      color: var(--cyan);
    }

    /* ── Form elements ── */
    label {
      display: block;
      font-size: 0.8rem;
      color: var(--text-2);
      margin-bottom: 6px;
    }
    input[type="text"],
    input[type="email"],
    select {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border-2);
      border-radius: 6px;
      color: var(--text-1);
      font-size: 0.875rem;
      padding: 9px 12px;
      margin-bottom: 14px;
      outline: none;
      font-family: var(--font-mono);
      appearance: auto;
    }
    input:focus, select:focus { border-color: var(--orange); }

    /* ── Buttons ── */
    button {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      border-radius: 7px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: all 120ms;
    }
    .btn-primary  { background: var(--orange); color: #fff; }
    .btn-primary:hover  { background: #ff7033; }
    .btn-primary:disabled  { opacity: 0.5; cursor: not-allowed; }
    .btn-outline  { background: transparent; color: var(--text-1); border: 1px solid var(--border-2); }
    .btn-outline:hover { border-color: var(--text-2); background: var(--bg-elevated); }

    .btn-row { display: flex; gap: 10px; align-items: center; margin-top: 4px; }

    /* ── Preview pane ── */
    #preview-pane {
      margin-top: 16px;
      display: none;
    }
    .preview-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 12px;
    }
    .preview-tab {
      padding: 5px 14px;
      border-radius: 6px;
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      background: var(--bg-elevated);
      border: 1px solid var(--border-2);
      color: var(--text-2);
      transition: all 100ms;
    }
    .preview-tab.active { background: var(--orange); color: #fff; border-color: var(--orange); }
    #preview-html-frame {
      width: 100%;
      height: 480px;
      border: 1px solid var(--border-2);
      border-radius: 8px;
      background: #fff;
    }
    #preview-text-out {
      display: none;
      width: 100%;
      background: var(--bg-elevated);
      border: 1px solid var(--border-2);
      border-radius: 8px;
      padding: 16px;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--text-2);
      white-space: pre-wrap;
      max-height: 480px;
      overflow-y: auto;
    }
    .preview-subject {
      font-size: 0.82rem;
      color: var(--text-3);
      font-family: var(--font-mono);
      margin-bottom: 10px;
    }

    /* ── Auth gate ── */
    #auth-gate {
      max-width: 400px;
      margin: 80px auto;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 32px;
    }
    #auth-gate h2 { font-size: 1.1rem; margin-bottom: 20px; color: var(--text-1); }
    #auth-gate label { display: block; font-size: 0.8rem; color: var(--text-2); margin-bottom: 6px; }
    #auth-gate input[type="password"] {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border-2);
      border-radius: 6px;
      color: var(--text-1);
      font-size: 0.9rem;
      padding: 10px 12px;
      margin-bottom: 16px;
      outline: none;
    }
    #auth-gate input[type="password"]:focus { border-color: var(--orange); }

    #email-app { display: none; }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-2);
      border-radius: 8px;
      padding: 12px 20px;
      font-size: 0.875rem;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 250ms, transform 250ms;
      pointer-events: none;
      z-index: 999;
      max-width: 400px;
    }
    #toast.visible  { opacity: 1; transform: translateY(0); }
    #toast.success  { border-color: #22c55e; color: #4ade80; }
    #toast.error    { border-color: #ef4444; color: #f87171; }
    #toast.info     { border-color: var(--cyan); color: var(--cyan); }
  </style>
</head>
<body>

  <!-- ── Auth gate ── -->
  <div id="auth-gate">
    <h2>🔐 Admin — Email</h2>
    <label for="token-input">Admin secret</label>
    <input id="token-input" type="password" placeholder="Enter ADMIN_SECRET…" autocomplete="current-password" />
    <button class="btn-primary" id="auth-btn" style="width:100%">Unlock</button>
    <p id="auth-error" style="color:#f87171;font-size:0.8rem;margin-top:10px;display:none;"></p>
  </div>

  <!-- ── Main app (hidden until authed) ── -->
  <div id="email-app" class="container">
    <div class="breadcrumb">
      <a href="/admin/config">← Site Config</a>
      &nbsp;/&nbsp;
      <a href="/admin/blog">Blog</a>
      &nbsp;/&nbsp;
      Email
    </div>

    <h1>Email</h1>

    <!-- ── Configuration status ── -->
    <div class="section">
      <h2>Configuration</h2>
      <div id="status-loading" style="color:var(--text-3);font-size:0.85rem;">Loading status…</div>
      <div id="status-content" style="display:none;">
        <div class="status-grid" id="status-grid"></div>
        <p style="font-size:0.82rem;color:var(--text-2);margin-bottom:10px;">
          Send strategy: <span id="strategy-badge" class="strategy-badge">—</span>
        </p>
        <p id="not-ready-msg" style="font-size:0.82rem;color:var(--red);display:none;">
          ⚠ <code>FROM_EMAIL</code> is not configured. Set it in
          <code>wrangler.toml [vars]</code> and redeploy before sending emails.
        </p>
        <p style="font-size:0.78rem;color:var(--text-3);margin-top:8px;">
          To change secrets (DKIM_PRIVATE_KEY etc.) use the CLI:
          <code style="font-family:var(--font-mono);">wrangler secret put DKIM_PRIVATE_KEY</code>.
          Never edit them in the Cloudflare dashboard — see wrangler.toml for why.
        </p>
      </div>
    </div>

    <!-- ── Template preview ── -->
    <div class="section">
      <h2>Template Preview</h2>
      <label for="preview-template">Template</label>
      <select id="preview-template">
        <option value="waitlistWelcome">waitlistWelcome</option>
      </select>

      <label for="preview-email">Email (embedded in template)</label>
      <input type="email" id="preview-email" value="preview@example.com" placeholder="preview@example.com" />

      <label for="preview-segment">Segment (optional)</label>
      <select id="preview-segment">
        <option value="">— none —</option>
        <option value="list-maker">list-maker</option>
        <option value="privacy-vendor">privacy-vendor</option>
        <option value="individual">individual</option>
      </select>

      <div class="btn-row">
        <button class="btn-outline" id="preview-btn">Preview</button>
        <span id="preview-loading" style="font-size:0.8rem;color:var(--text-3);display:none;">Rendering…</span>
      </div>

      <div id="preview-pane">
        <p class="preview-subject">Subject: <strong id="preview-subject-text"></strong></p>
        <div class="preview-tabs">
          <button class="preview-tab active" id="tab-html" onclick="showTab('html')">HTML</button>
          <button class="preview-tab"         id="tab-text" onclick="showTab('text')">Plain text</button>
        </div>
        <iframe id="preview-html-frame" sandbox="allow-same-origin" title="Email HTML preview"></iframe>
        <pre id="preview-text-out"></pre>
      </div>
    </div>

    <!-- ── Send test email ── -->
    <div class="section">
      <h2>Send Test Email</h2>
      <p style="font-size:0.82rem;color:var(--text-2);margin-bottom:16px;">
        Renders a template and delivers it via the configured send strategy.
        Requires <code>FROM_EMAIL</code> to be set.
      </p>

      <label for="send-to">Recipient</label>
      <input type="email" id="send-to" placeholder="you@example.com" />

      <label for="send-template">Template</label>
      <select id="send-template">
        <option value="waitlistWelcome">waitlistWelcome</option>
      </select>

      <label for="send-segment">Segment (optional)</label>
      <select id="send-segment">
        <option value="">— none —</option>
        <option value="list-maker">list-maker</option>
        <option value="privacy-vendor">privacy-vendor</option>
        <option value="individual">individual</option>
      </select>

      <div class="btn-row">
        <button class="btn-primary" id="send-btn">Send test</button>
        <span id="send-loading" style="font-size:0.8rem;color:var(--text-3);display:none;">Sending…</span>
      </div>
    </div>
  </div>

  <div id="toast"></div>

  <script>
    // ── Globals ───────────────────────────────────────────────────────────────
    let adminToken = '';
    let toastTimer;

    // ── Auth helpers ──────────────────────────────────────────────────────────
    const COOKIE_NAME = 'admin_token';

    function getStoredToken() {
      const urlToken = new URLSearchParams(window.location.search).get('token');
      if (urlToken) {
        const secure = window.location.protocol === 'https:' ? '; Secure' : '';
        document.cookie = `${COOKIE_NAME}=${encodeURIComponent(urlToken)}; path=/admin; SameSite=Strict${secure}`;
        const url = new URL(window.location.href);
        url.searchParams.delete('token');
        window.history.replaceState({}, '', url.toString());
        return urlToken;
      }
      const match = document.cookie.match(new RegExp(`(?:^|;\\s*)${COOKIE_NAME}=([^;]+)`));
      return match ? decodeURIComponent(match[1]) : null;
    }

    function storeToken(token) {
      const secure = window.location.protocol === 'https:' ? '; Secure' : '';
      document.cookie = `${COOKIE_NAME}=${encodeURIComponent(token)}; path=/admin; SameSite=Strict${secure}`;
    }

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg, type = 'success') {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.className = `visible ${type}`;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { el.className = ''; }, 4000);
    }

    // ── Auth request helper ───────────────────────────────────────────────────
    function authHeaders() {
      const h = { 'Content-Type': 'application/json' };
      if (adminToken) h['Authorization'] = `Bearer ${adminToken}`;
      return h;
    }

    // ── Status panel ──────────────────────────────────────────────────────────
    async function loadStatus() {
      try {
        const res = await fetch('/admin/email/status', { headers: authHeaders() });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();

        document.getElementById('status-loading').style.display = 'none';
        document.getElementById('status-content').style.display = 'block';

        const grid = document.getElementById('status-grid');
        grid.innerHTML = '';
        for (const [key, present] of Object.entries(data.configured)) {
          const div = document.createElement('div');
          div.className = 'status-item';
          div.innerHTML = `
            <div class="key">${escHtml(key)}</div>
            <div class="val ${present ? 'yes' : 'no'}">${present ? '✓ configured' : '✗ not set'}</div>
          `;
          grid.appendChild(div);
        }

        document.getElementById('strategy-badge').textContent = data.sendStrategy;
        if (!data.ready) {
          document.getElementById('not-ready-msg').style.display = 'block';
        }
      } catch (err) {
        console.error('Failed to load email status:', err);
        document.getElementById('status-loading').textContent = 'Failed to load status — check console.';
      }
    }

    // ── Preview ───────────────────────────────────────────────────────────────
    function showTab(tab) {
      const htmlFrame = document.getElementById('preview-html-frame');
      const textOut   = document.getElementById('preview-text-out');
      document.getElementById('tab-html').classList.toggle('active', tab === 'html');
      document.getElementById('tab-text').classList.toggle('active', tab === 'text');
      htmlFrame.style.display = tab === 'html' ? 'block' : 'none';
      textOut.style.display   = tab === 'text' ? 'block' : 'none';
    }

    document.getElementById('preview-btn').addEventListener('click', async () => {
      const template = document.getElementById('preview-template').value;
      const email    = document.getElementById('preview-email').value.trim();
      const segment  = document.getElementById('preview-segment').value || null;

      const loadingEl = document.getElementById('preview-loading');
      loadingEl.style.display = 'inline';
      document.getElementById('preview-btn').disabled = true;

      try {
        const params = new URLSearchParams({ template });
        if (email) params.set('email', email);
        if (segment) params.set('segment', segment);

        const res = await fetch(`/admin/email/preview?${params.toString()}`, { headers: authHeaders() });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          showToast(`Preview failed: ${data.error ?? res.status}`, 'error');
          return;
        }

        const data = await res.json();
        document.getElementById('preview-subject-text').textContent = data.subject;

        const frame = document.getElementById('preview-html-frame');
        // Revoke the previous Blob URL before creating a new one to prevent
        // accumulating object URLs in memory during a long-lived admin session.
        if (frame.src && frame.src.startsWith('blob:')) {
          URL.revokeObjectURL(frame.src);
        }
        const blob  = new Blob([data.html], { type: 'text/html' });
        frame.src   = URL.createObjectURL(blob);

        document.getElementById('preview-text-out').textContent = data.text;
        document.getElementById('preview-pane').style.display = 'block';
        showTab('html');
      } catch (err) {
        showToast('Network error — could not preview.', 'error');
        console.error('Preview error:', err);
      } finally {
        loadingEl.style.display = 'none';
        document.getElementById('preview-btn').disabled = false;
      }
    });

    // ── Send test ─────────────────────────────────────────────────────────────
    document.getElementById('send-btn').addEventListener('click', async () => {
      const to       = document.getElementById('send-to').value.trim();
      const template = document.getElementById('send-template').value;
      const segment  = document.getElementById('send-segment').value || null;

      if (!to) { showToast('Enter a recipient email.', 'error'); return; }

      const loadingEl = document.getElementById('send-loading');
      const btn       = document.getElementById('send-btn');
      loadingEl.style.display = 'inline';
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const res = await fetch('/admin/email/send-test', {
          method: 'POST',
          headers: authHeaders(),
          body: JSON.stringify({
            to,
            template,
            params: { email: to, segment },
          }),
        });

        const data = await res.json().catch(() => ({}));

        if (res.ok && data.success) {
          showToast(`✓ Test email sent to ${to} via ${data.strategy}.`);
        } else if (res.status === 503) {
          showToast(`FROM_EMAIL not configured — cannot send.`, 'error');
        } else {
          showToast(`Error: ${data.error ?? 'Unknown error'}`, 'error');
        }
      } catch (err) {
        showToast('Network error — could not send.', 'error');
        console.error('Send test error:', err);
      } finally {
        loadingEl.style.display = 'none';
        btn.disabled = false;
        btn.textContent = 'Send test';
      }
    });

    // ── HTML escaping ─────────────────────────────────────────────────────────
    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    // ── Boot ──────────────────────────────────────────────────────────────────
    function unlockApp(token) {
      adminToken = token;
      document.getElementById('auth-gate').style.display = 'none';
      document.getElementById('email-app').style.display = 'block';
      loadStatus();
    }

    async function checkBetterAuthSession() {
      try {
        const res = await fetch('/api/auth/session');
        if (res.ok) {
          const data = await res.json();
          if (data?.session) { unlockApp(''); return true; }
        }
      } catch { /* fall through */ }
      return false;
    }

    (async () => {
      const hasSession = await checkBetterAuthSession();
      if (!hasSession) {
        const existing = getStoredToken();
        if (existing) unlockApp(existing);
      }
    })();

    document.getElementById('auth-btn').addEventListener('click', () => {
      const token = document.getElementById('token-input').value.trim();
      if (!token) return;
      fetch('/admin/email/status', {
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      }).then(res => {
        if (res.status === 403) {
          const el = document.getElementById('auth-error');
          el.textContent = 'Incorrect secret — try again.';
          el.style.display = 'block';
        } else if (res.ok || res.status === 503) {
          storeToken(token);
          document.getElementById('auth-error').style.display = 'none';
          unlockApp(token);
        } else {
          const el = document.getElementById('auth-error');
          el.textContent = `Server error (${res.status}) — check ADMIN_SECRET and DATABASE_URL.`;
          el.style.display = 'block';
        }
      }).catch(() => {
        const el = document.getElementById('auth-error');
        el.textContent = 'Network error — check your connection.';
        el.style.display = 'block';
      });
    });

    document.getElementById('token-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('auth-btn').click();
    });
  </script>
</body>
</html>

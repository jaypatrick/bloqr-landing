---
// src/pages/admin/login.astro — /admin/login
// Better Auth admin login page. Auth is handled by /api/auth/* edge routes.
const callbackUrl = '/admin/config';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — Bloqr</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    :root {
      --bg-base:     #070B14;
      --bg-surface:  #0E1829;
      --bg-elevated: #162035;
      --orange:      #FF5500;
      --cyan:        #00D4FF;
      --text-1:      #F1F5F9;
      --text-2:      #94A3B8;
      --text-3:      #475569;
      --border:      #1E2D40;
      --border-2:    #2A3F5A;
      --font-display: system-ui, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-base);
      color: var(--text-1);
      font-family: var(--font-display);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .login-container {
      width: 100%;
      max-width: 420px;
    }

    .login-card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 40px 36px;
      text-align: center;
    }

    .logo {
      font-size: 2.5rem;
      margin-bottom: 16px;
      line-height: 1;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 0.875rem;
      color: var(--text-2);
      margin-bottom: 32px;
      line-height: 1.5;
    }

    .btn-github {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 13px 20px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-2);
      border-radius: 10px;
      color: var(--text-1);
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 120ms, border-color 120ms;
      cursor: pointer;
    }
    .btn-github:hover {
      background: #1e2d40;
      border-color: var(--cyan);
    }
    .btn-github svg {
      flex-shrink: 0;
    }

    .note {
      margin-top: 24px;
      font-size: 0.78rem;
      color: var(--text-3);
      line-height: 1.5;
    }

    .divider {
      margin: 28px 0;
      border: none;
      border-top: 1px solid var(--border);
    }

    .legacy-section h3 {
      font-size: 0.8rem;
      color: var(--text-3);
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    label {
      display: block;
      font-size: 0.78rem;
      color: var(--text-2);
      text-align: left;
      margin-bottom: 6px;
    }

    input[type="password"] {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border-2);
      border-radius: 7px;
      color: var(--text-1);
      font-size: 0.875rem;
      padding: 10px 12px;
      margin-bottom: 12px;
      outline: none;
    }
    input[type="password"]:focus { border-color: var(--orange); }

    .btn-legacy {
      width: 100%;
      padding: 10px 20px;
      background: var(--orange);
      border: none;
      border-radius: 7px;
      color: #fff;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 120ms;
    }
    .btn-legacy:hover { background: #ff7033; }

    #legacy-error {
      color: #f87171;
      font-size: 0.8rem;
      margin-top: 8px;
      display: none;
      text-align: left;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-card">
      <div class="logo">🛡️</div>
      <h1>Bloqr Admin</h1>
      <p class="subtitle">
        Sign in with your GitHub account to access the admin dashboard.
      </p>

      <a
        href={`/api/auth/signin/github?callbackURL=${encodeURIComponent(callbackUrl)}`}
        class="btn-github"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        Sign in with GitHub
      </a>

      <p class="note" id="access-note">
        Only authorized GitHub accounts can access admin. Contact Jayson if you need access.
      </p>

      <hr class="divider" />

      <!-- Legacy password gate — kept until Better Auth is fully live in prod -->
      <div class="legacy-section">
        <h3>Legacy access</h3>
        <label for="legacy-token">Admin secret</label>
        <input id="legacy-token" type="password" placeholder="Enter ADMIN_SECRET…" autocomplete="current-password" />
        <button class="btn-legacy" id="legacy-btn">Unlock with secret</button>
        <p id="legacy-error">Incorrect secret — try again.</p>
      </div>
    </div>
  </div>

  <script>
    // Show error message if OAuth returned an error
    (function () {
      const params = new URLSearchParams(window.location.search);
      const error  = params.get('error');
      const note   = document.getElementById('access-note');
      if (error === 'access_denied' || error === 'OAuthAccountNotLinked') {
        note.textContent = 'Your GitHub account does not have admin access to Bloqr.';
        note.style.color = '#f87171';
      }
    })();

    // Legacy ADMIN_SECRET gate — redirects to /admin/config on success
    const COOKIE_NAME = 'admin_token';
    const CALLBACK    = new URLSearchParams(window.location.search).get('callbackURL') ?? '/admin/config';

    document.getElementById('legacy-btn').addEventListener('click', () => {
      const token = document.getElementById('legacy-token').value.trim();
      if (!token) return;

      fetch('/admin/config', {
        method:  'POST',
        headers: {
          'Content-Type':  'application/json',
          'Authorization': `Bearer ${token}`,
        },
        body: JSON.stringify({ key: '__ping__', value: '__ping__' }),
      }).then(res => {
        if (res.status === 403) {
          const err = document.getElementById('legacy-error');
          err.textContent = 'Incorrect secret — try again.';
          err.style.display = 'block';
        } else if (res.status === 404 || res.status === 200) {
          document.cookie = `${COOKIE_NAME}=${encodeURIComponent(token)}; path=/admin; SameSite=Strict; Secure`;
          window.location.href = CALLBACK;
        } else {
          const err = document.getElementById('legacy-error');
          err.textContent = `Server error (${res.status}) — check that ADMIN_SECRET and DATABASE_URL are configured.`;
          err.style.display = 'block';
        }
      }).catch(() => {
        const err = document.getElementById('legacy-error');
        err.textContent = 'Network error — check your connection.';
        err.style.display = 'block';
      });
    });

    document.getElementById('legacy-token').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('legacy-btn').click();
    });
  </script>
</body>
</html>

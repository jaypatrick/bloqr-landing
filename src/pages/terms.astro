---
export const prerender = true;
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_URL, META } from '../config';

const meta = {
  title:       'Terms of Service — Bloqr AI',
  description: 'Terms of Service for Bloqr AI. Plain English — no legalese. Pre-launch, so the terms are simple.',
  url:         `${SITE_URL}/terms`,
  image:       `${SITE_URL}${META.ogImage}`,
};

const termsSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": meta.url,
      "name": meta.title,
      "url": meta.url,
      "description": meta.description,
      "additionalType": "https://schema.org/TermsOfService"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Terms of Service", "item": `${SITE_URL}/terms` }
      ]
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={meta.title}
    description={meta.description}
    canonicalURL={meta.url}
    ogImage={meta.image}
  />
  <SchemaOrg schema={termsSchema} />
</head>
<body>
  <Nav client:load transition:persist="nav" />

  <main id="main-content" class="legal-page">

    <header class="page-header">
      <div class="container">
        <div class="header-label">Legal</div>
        <h1>Terms of Service</h1>
        <p class="effective-date">Effective date: April 2026 (pre-launch)</p>
      </div>
    </header>

    <div class="container prose-wrap">

      <section class="prose-section" aria-labelledby="prelaunch-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Pre-launch</span>
          </div>
          <div class="prose-body">
            <h2 id="prelaunch-heading">The service is in development.</h2>
            <p>Bloqr is a pre-launch product. The waitlist on this page collects interest only — no payment is taken, no contract is formed, and no service is being provided yet. By joining the waitlist you are expressing interest in being notified when the product is ready. That's it.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="agreement-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">What you're agreeing to</span>
          </div>
          <div class="prose-body">
            <h2 id="agreement-heading">By joining the waitlist, you agree to receive one email.</h2>
            <p>That email is sent when early access to Bloqr is available for your account. It contains an access link and nothing else. You can unsubscribe at any time before that email is sent by emailing <a href="mailto:legal@bloqr.ai">legal@bloqr.ai</a>.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="promise-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">What we promise</span>
          </div>
          <div class="prose-body">
            <h2 id="promise-heading">What we promise you.</h2>
            <ul>
              <li>We will not spam you. One email, when you're in.</li>
              <li>We will not sell your email address to any third party.</li>
              <li>We will not use your email for any purpose other than notifying you when Bloqr launches.</li>
              <li>We will delete your data within 30 days if you request it.</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="ip-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Intellectual property</span>
          </div>
          <div class="prose-body">
            <h2 id="ip-heading">Intellectual property.</h2>
            <p>The adblock filter list compiler at the core of Bloqr is GPL-3.0 licensed and available on GitHub. You are free to use, fork, and audit it under the terms of that license.</p>
            <p>The Bloqr name, logo, and managed platform (AI features, vendor integrations, dashboard) are © 2026 Bloqr. All rights reserved.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="liability-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Limitation of liability</span>
          </div>
          <div class="prose-body">
            <h2 id="liability-heading">Limitation of liability.</h2>
            <p>This is pre-launch software. The service is provided "as is" with no warranties, express or implied. To the maximum extent permitted by applicable law, Bloqr shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of, or inability to use, the service.</p>
            <p>This limitation applies whether the claim is based on warranty, contract, tort, or any other legal theory, even if Bloqr has been advised of the possibility of such damage.</p>
          </div>
        </div>
      </section>

      <section class="prose-section" aria-labelledby="contact-heading">
        <div class="prose-grid">
          <div class="prose-sidebar">
            <span class="sidebar-label">Contact</span>
          </div>
          <div class="prose-body">
            <h2 id="contact-heading">Contact</h2>
            <p>Legal questions: <a href="mailto:legal@bloqr.ai">legal@bloqr.ai</a></p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  .legal-page { color: var(--text-1); }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .page-header {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--border);
  }

  .header-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .effective-date {
    font-size: 0.85rem;
    color: var(--text-3);
  }

  .prose-wrap {
    padding-top: 0;
    padding-bottom: 80px;
  }

  .prose-section {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }

  .prose-grid {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 700px) {
    .prose-grid { grid-template-columns: 1fr; gap: 12px; }
    .prose-sidebar { display: none; }
  }

  .prose-sidebar { padding-top: 6px; }

  .sidebar-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .prose-body h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-1);
  }

  .prose-body p {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .prose-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .prose-body li {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.65;
    padding-left: 18px;
    position: relative;
  }

  .prose-body li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--text-3);
    font-size: 0.8rem;
  }

  .prose-body strong { color: var(--text-1); }

  .prose-body a {
    color: var(--orange);
    text-decoration: none;
    transition: color 150ms;
  }

  .prose-body a:hover { color: var(--orange-hover); }
</style>

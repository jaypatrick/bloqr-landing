# Disable Astro telemetry in all environments
ASTRO_TELEMETRY_DISABLED=1

# Neon database connection string (adblock-compiler DB)
# DATABASE_URL=postgres://...

# Cloudflare secrets (set via `wrangler secret put` or .dev.vars locally)
# See .dev.vars for local development values — never commit that file

# Plausible analytics domain (defaults to 'bloqr.ai' if not set)
PUBLIC_PLAUSIBLE_DOMAIN=bloqr.ai

# PostHog project API key (leave empty to disable PostHog in production)
PUBLIC_POSTHOG_KEY=

# Cloudflare Web Analytics beacon token (leave empty to disable)
PUBLIC_CF_BEACON_TOKEN=

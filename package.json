{
  "name": "adblock-compiler-landing",
  "version": "0.1.0",
  "description": "AdBlock Compiler landing page — Astro + Svelte, deployed to Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "sync-blog": "npx tsx scripts/sync-blog-from-db.ts",
    "migrate-blog": "npx tsx scripts/migrate-blog-posts.ts",
    "migrate:auth": "tsx scripts/migrate-better-auth.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^7.0.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@neondatabase/serverless": "^1.0.2",
    "astro": "^5.0.0",
    "better-auth": "^1.6.0",
    "posthog-js": "^1.364.7",
    "svelte": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^22.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}

# Copy this to .dev.vars (gitignored) and fill in real values for local dev
# Run: cp .dev.vars.example .dev.vars

DATABASE_URL=postgresql://your-neon-connection-string-here
APOLLO_API_KEY=your-apollo-api-key
ADMIN_SECRET=any-strong-random-string-for-local-dev

# Better Auth — required for /api/auth/* and /admin/* session validation
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
# Local dev value shown below. For production, set in the Cloudflare dashboard:
#   Production: https://bloqr.dev
BETTER_AUTH_URL=http://localhost:4321

# GitHub OAuth — create an OAuth App at https://github.com/settings/developers
# Callback URLs to add to your GitHub OAuth App:
#   Local dev:   http://localhost:4321/api/auth/callback/github
#   Production:  https://bloqr.dev/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# BETTER_AUTH_TRUSTED_ORIGINS — optional; comma-separated trusted origins for cross-app SSO
# Not needed until app.bloqr.dev / docs.bloqr.dev are live
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.bloqr.dev,https://docs.bloqr.dev

# ─── Email (CF Email Workers binding) ─────────────────────────────────────────
# FROM_EMAIL sets the sender address for all outbound transactional email.
# It is set as a plain var in wrangler.toml [vars] — no secret needed.
# The SEND_EMAIL binding (cloudflare:email) is declared in wrangler.toml and
# handles DKIM/SPF automatically through Cloudflare Email Routing.
# No API key is required. The binding only works inside the CF Workers runtime;
# use `npm run preview` (wrangler dev) to exercise email paths locally.
FROM_EMAIL=Bloqr <hello@bloqr.dev>

# ─── PostHog server-side analytics ───────────────────────────────────────────
# Required for server-side event tracking in the CF Worker (functions/waitlist.ts).
# Set as Cloudflare secrets in production: wrangler secret put POSTHOG_PROJECT_TOKEN
# POSTHOG_HOST defaults to US cloud (https://us.i.posthog.com) if unset.
POSTHOG_PROJECT_TOKEN=your-posthog-project-token
# POSTHOG_HOST=https://us.i.posthog.com

# ─── Neon migration note ──────────────────────────────────────────────────────
# After setting DATABASE_URL, run the email schema migration to add
# email_message_id to the waitlist table:
#   npm run migrate:email
